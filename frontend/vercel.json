{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/cbw-frontend/browser",
  "installCommand": "npm install",
  "framework": "angular",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://cbw-backend.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
